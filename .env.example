DATABASE_URL=mysql://user:pass@host:port/db
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=local-dev
OAUTH_SERVER_URL=http://localhost:3000
VITE_ANALYTICS_ENDPOINT=http://localhost:3000
VITE_ANALYTICS_WEBSITE_ID=local
# GA4 frontend tracking (build-time, injected into client/index.html + the app).
# This is the GA4 **Web Data Stream Measurement ID** ("G-XXXXXXXXXX") from
# GA4 Admin → Data Streams → your Web stream — NOT the numeric GA4 *property* id
# (that's the backend GA4_PROPERTY_ID below). Leave blank to keep frontend GA4
# tracking off (the site sends nothing to GA4; Google Ads is unaffected).
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret
RESEND_API_KEY=re_YOURKEY

# Referral form (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Internal presentation page (/presentation-2026) access password
VITE_PRESENTATION_PASSWORD=set-a-new-password

# ── SMS provider ──
# ACTIVE: Telnyx (all sends: campaigns, scheduled, appointments, rebate, referral)
# API key: Telnyx portal → Account → Keys & Credentials → API Keys (starts "KEY...").
TELNYX_API_KEY=
# Sender: the 10DLC-registered messaging number, E.164. NEVER hard-coded in
# code — the app reads it from this env var only. The number MUST be assigned
# (in the Telnyx portal) to the messaging profile bound to the approved
# Customer Care 10DLC campaign below, or carriers will filter the messages.
#   Approved campaign — Telnyx Campaign ID: 4b30019f-57fe-9693-5487-67707b2b116c
#   Approved campaign — TCR Campaign ID:    CVTLF1G
# Set this to whatever number is provisioned on that campaign in production.
TELNYX_FROM_NUMBER=
# Webhook signature verification. REQUIRED in production: Telnyx portal →
# Account → Keys & Credentials → Public Key (base64 raw Ed25519 key). In
# production the server REFUSES TO START without it, and inbound webhooks are
# rejected (503) if it is missing — signature checks are never silently skipped.
TELNYX_PUBLIC_KEY=
# Dev/test ONLY: explicitly bypass inbound webhook signature verification when
# you have no public key locally. Ignored in production. A missing public key
# does NOT imply bypass — you must set this flag on purpose.
TELNYX_WEBHOOK_SIGNATURE_BYPASS=false
# LEGACY/DISABLED (July 2026): TextBelt no longer used for sending.
# Do NOT set TEXTBELT_API_KEY — remove it from Netlify env after rotating it off.

# ── Accounting: QuickBooks Online (Task 7) ──
# Intuit app credentials (developer.intuit.com → your app → Keys & OAuth).
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered on the Intuit app.
QUICKBOOKS_REDIRECT_URI=https://mechanicalenterprise.com/api/integrations/quickbooks/callback
# sandbox | production — selects the QBO API base host.
QUICKBOOKS_ENVIRONMENT=sandbox
# Sales-document sync poller (Estimates → Opportunity Center).
# Interval in ms between incremental pulls (default 180000 = 3 min; floor 30s).
QUICKBOOKS_POLL_INTERVAL_MS=180000
# Set to "false" to disable the background poller (manual "Sync Now" still works).
QUICKBOOKS_POLL_ENABLED=true
# SAFETY GATE: outbound SMS follow-ups stay OFF until 10DLC is approved.
# Text follow-up tasks are created but never dispatched while this is not "true".
SMS_FOLLOWUPS_ENABLED=false

# ── Secrets encryption (Task 7) ──
# 32-byte key, hex-encoded (64 hex chars). Generate: openssl rand -hex 32
# Encrypts QuickBooks OAuth tokens at rest AND the Google refresh token used by
# Search Console. Rotating it invalidates stored tokens (reconnect required).
# NEVER commit the real value.
ENCRYPTION_KEY=

# ── Google OAuth (shared: Calendar + Google Ads + Search Console + GA4) ──
# One OAuth client is reused across all Google integrations. The SEO Intelligence
# module (Search Console) and the GA4 Analytics module do NOT add a second OAuth
# flow — they reuse this grant and the connection stored by the Google Calendar
# connect flow. Google Cloud console → APIs & Services → Credentials → OAuth 2.0.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
# Must EXACTLY match a Redirect URI registered on the OAuth client. This is the
# consent-callback used to connect Google; the consent screen must include the
# Search Console scope (see below) for SEO sync to work.
GOOGLE_CALENDAR_REDIRECT_URI=https://mechanicalenterprise.com/api/integrations/google-calendar/callback
# REQUIRED SCOPE for SEO: https://www.googleapis.com/auth/webmasters.readonly
# REQUIRED SCOPE for GA4: https://www.googleapis.com/auth/analytics.readonly
# Both are requested by the connect flow. Connections authorized BEFORE a scope
# was added must RE-CONSENT once (disconnect + reconnect Google) to grant it.

# ── SEO Intelligence (Search Console sync) ──
# The Search Console PROPERTY to sync — must match the property EXACTLY as shown
# in Search Console. Use ONE of these two forms:
#   Domain property:      sc-domain:mechanicalenterprise.com
#   URL-prefix property:  https://mechanicalenterprise.com/   (trailing slash, exact scheme/host)
SEO_GSC_SITE_URL=sc-domain:mechanicalenterprise.com
# Shared secret for the cron/external sync endpoint POST /api/seo/sync.
# Callers must send it as the `x-seo-sync-secret` header. If unset, the endpoint
# is UNAUTHENTICATED (dev only) — always set this in production. Generate: openssl rand -hex 32
SEO_SYNC_CRON_SECRET=
# Monthly organic-leads goal shown on the dashboard (default 80).
SEO_LEADS_GOAL=80
# Max pages per sync to run through the URL Inspection API (quota-limited; default 20).
SEO_INSPECT_LIMIT=20
# Set to "false" to disable the in-process daily sync scheduler on an instance
# (e.g. when an external cron drives POST /api/seo/sync, or on all-but-one replica).
# Safe to leave enabled everywhere: a MySQL advisory lock ensures only one runs.
SEO_SYNC_SCHEDULER_ENABLED=true
# Optional fallback origin used to turn Search Console page paths into full URLs
# when SEO_GSC_SITE_URL is a domain property (default https://mechanicalenterprise.com/).
PUBLIC_SITE_URL=https://mechanicalenterprise.com/

# ── GA4 Analytics (Google Analytics Data API sync) ──
# The GA4 PROPERTY ID to sync — the NUMERIC id from GA4 Admin → Property Settings
# (e.g. "480827123"). NOT the "G-XXXXXXX" measurement id and NOT a "UA-…" id; a
# non-numeric value is rejected and analytics stays disabled. Leave blank to keep
# the whole GA4 module dormant. A "properties/480827123" form is also accepted.
GA4_PROPERTY_ID=
# Shared secret for the cron/external sync endpoint POST /api/analytics/ga4/sync.
# Callers must send it as the `x-ga4-sync-secret` header. If UNSET the endpoint is
# DISABLED (503) — it never runs unauthenticated. Generate: openssl rand -hex 32
GA4_SYNC_CRON_SECRET=
# In-process daily sync scheduler. OPT-IN and OFF by default: it only starts when
# set to exactly "true". Leave unset/blank to keep automated GA4 syncing disabled.
GA4_SYNC_SCHEDULER_ENABLED=
# Optional rolling window (days) pulled each sync (default 90).
GA4_WINDOW_DAYS=90
