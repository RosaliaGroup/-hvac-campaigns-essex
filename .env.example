DATABASE_URL=mysql://user:pass@host:port/db
VITE_OAUTH_PORTAL_URL=http://localhost:3000
VITE_APP_ID=local-dev
OAUTH_SERVER_URL=http://localhost:3000
VITE_ANALYTICS_ENDPOINT=http://localhost:3000
VITE_ANALYTICS_WEBSITE_ID=local
JWT_SECRET=your-jwt-secret
SESSION_SECRET=your-session-secret
RESEND_API_KEY=re_YOURKEY

# Referral form (Supabase)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Internal presentation page (/presentation-2026) access password
VITE_PRESENTATION_PASSWORD=set-a-new-password

# ── SMS provider ──
# ACTIVE: Telnyx (all sends: campaigns, scheduled, appointments, rebate, referral)
# API key: Telnyx portal → Account → Keys & Credentials → API Keys (starts "KEY...").
TELNYX_API_KEY=
# Sender: the 10DLC-registered messaging number, E.164. Production = +15516007027.
TELNYX_FROM_NUMBER=+15516007027
# Webhook signature verification. REQUIRED in production: Telnyx portal →
# Account → Keys & Credentials → Public Key (base64 raw Ed25519 key). In
# production the server REFUSES TO START without it, and inbound webhooks are
# rejected (503) if it is missing — signature checks are never silently skipped.
TELNYX_PUBLIC_KEY=
# Dev/test ONLY: explicitly bypass inbound webhook signature verification when
# you have no public key locally. Ignored in production. A missing public key
# does NOT imply bypass — you must set this flag on purpose.
TELNYX_WEBHOOK_SIGNATURE_BYPASS=false
# LEGACY/DISABLED (July 2026): TextBelt no longer used for sending.
# Do NOT set TEXTBELT_API_KEY — remove it from Netlify env after rotating it off.

# ── Accounting: QuickBooks Online (Task 7) ──
# Intuit app credentials (developer.intuit.com → your app → Keys & OAuth).
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=
# Must EXACTLY match a Redirect URI registered on the Intuit app.
QUICKBOOKS_REDIRECT_URI=https://mechanicalenterprise.com/api/integrations/quickbooks/callback
# sandbox | production — selects the QBO API base host.
QUICKBOOKS_ENVIRONMENT=sandbox
# Sales-document sync poller (Estimates → Opportunity Center).
# Interval in ms between incremental pulls (default 180000 = 3 min; floor 30s).
QUICKBOOKS_POLL_INTERVAL_MS=180000
# Set to "false" to disable the background poller (manual "Sync Now" still works).
QUICKBOOKS_POLL_ENABLED=true
# SAFETY GATE: outbound SMS follow-ups stay OFF until 10DLC is approved.
# Text follow-up tasks are created but never dispatched while this is not "true".
SMS_FOLLOWUPS_ENABLED=false

# ── Secrets encryption (Task 7) ──
# 32-byte key, hex-encoded (64 hex chars). Generate: openssl rand -hex 32
# Encrypts QuickBooks OAuth tokens at rest. Rotating it invalidates stored tokens
# (reconnect required). NEVER commit the real value.
ENCRYPTION_KEY=
